# ============================================
# AstroBar - Professional .gitignore (MODIFIED)
# ============================================

# ============================================
# Environment & Secrets
# ============================================
.env
.env.*
!.env.example
*.pem
ca.pem

# ============================================
# Dependencies
# ============================================
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Quitamos package-lock.json de aquí para que Railway sepa qué versiones instalar
# package-lock.json 

# ============================================
# Build Outputs (MODIFIED: dist is now allowed)
# ============================================
# dist/  <-- COMENTADO PARA QUE SE SUBA A GITHUB
build/
out/
.next/
# web-build/ <-- COMENTADO POR SEGURIDAD
static-build/
*.apk
*.aab
*.ipa

# ============================================
# Expo
# ============================================
.expo/
.expo-shared/

# ============================================
# Logs
# ============================================
logs/
*.log

# ============================================
# Database & Backups
# ============================================
*.sql
!migrations/*.sql
*.dump
*.backup
backups/

# ============================================
# Testing (Local Only)
# ============================================
coverage/
.nyc_output/
test-*
# *test* <-- CUIDADO: esto podría ignorar archivos importantes, mejor ser específico
!*.test.ts
diagnose-*
fix-*
sync-*
emergency-*
process-*
transfer-*
verify-*

# ============================================
# Documentation (Only README.md)
# ============================================
*.md
!README.md

# ============================================
# Scripts (Local Only)
# ============================================
*.bat
*.sh
!install_phase2.sh

# ============================================
# Temporary & Cache
# ============================================
.cache/
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ============================================
# IDE & Editors
# ============================================
.vscode/
.idea/
*.sublime-*
.project
.classpath
.settings/

# ============================================
# OS Files
# ============================================
.DS_Store
._*
Thumbs.db
desktop.ini

# ============================================
# Uploads (Keep structure)
# ============================================
server/uploads/profiles/*
!server/uploads/profiles/.gitkeep
server/uploads/businesses/*
!server/uploads/businesses/.gitkeep
server/uploads/products/*
!server/uploads/products/.gitkeep

# ============================================
# Backup & Old Files
# ============================================
*.BACKUP.*
*.OLD.*
*.old
*-old.*
*-backup.*

# ============================================
# Keep Essential Only
# ============================================
!package.json
!tsconfig.json
!drizzle.config.ts
!app.json
!eas.json
!babel.config.js
!metro.config.js
!README.md
!.env.example